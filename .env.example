# ============================================================
# GadaiKu — Environment Variables
# Salin ke .env.local dan isi semua nilai yang diperlukan
# ============================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GadaiKu
NODE_ENV=development

# Database PostgreSQL
# Lokal  : postgresql://postgres:password@localhost:5432/gadai_db
# Neon   : postgresql://user:pass@host/db?sslmode=require
DATABASE_URL="postgresql://postgres:120624@localhost:5432/gadai_db"

# Redis
# Lokal   : redis://localhost:6379
# Upstash : rediss://user:pass@host:port
REDIS_URL="redis://localhost:6379"

# JWT (gunakan random string minimal 32 karakter)
JWT_ACCESS_SECRET="ganti-ini-random-32-karakter-access-secret!"
JWT_REFRESH_SECRET="ganti-ini-random-32-karakter-refresh-secret!"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Bcrypt
BCRYPT_ROUNDS="12"

# ─── Payment Gateway ─────────────────────────────────────────
# Midtrans (https://dashboard.midtrans.com)
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"
MIDTRANS_CALLBACK_URL="http://localhost:3000/api/pembayaran/callback"

# ─── Notifikasi ──────────────────────────────────────────────
# WhatsApp via Fonnte (https://fonnte.com)
FONNTE_TOKEN=""

# Email via SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@gadaiku.com"

# ─── Storage ─────────────────────────────────────────────────
# AWS S3 atau MinIO
AWS_REGION="ap-southeast-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BUCKET_NAME="gadaiku-uploads"
AWS_ENDPOINT=""

# Cloudinary (alternatif S3)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ─── Opsional ────────────────────────────────────────────────
# Sentry error monitoring
SENTRY_DSN=""
